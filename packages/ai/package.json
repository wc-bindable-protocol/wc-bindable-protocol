{
  "name": "@wc-bindable/ai",
  "version": "0.4.0",
  "description": "Declarative AI inference component for Web Components. Streaming-first, multi-provider (OpenAI, Anthropic, Azure OpenAI) via wc-bindable-protocol.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auto": {
      "types": "./src/auto/auto.d.ts",
      "default": "./src/auto/auto.min.js"
    },
    "./auto/remoteEnv": {
      "types": "./src/auto/remoteEnv.d.ts",
      "default": "./src/auto/remoteEnv.min.js"
    }
  },
  "files": [
    "dist",
    "src/auto",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run __tests__",
    "test:watch": "vitest __tests__",
    "test:coverage": "vitest run __tests__ --coverage --coverage.provider=v8 --coverage.reporter=text --coverage.include=src/**/*.ts --coverage.exclude=src/types.ts --coverage.exclude=src/index.ts --coverage.exclude=src/debug.ts --coverage.exclude=src/auto/**/*.d.ts",
    "test:integration": "npm run build -w @wc-bindable/core -w @wc-bindable/remote -w @wc-bindable/ai && playwright test"
  },
  "keywords": [
    "web-components",
    "ai",
    "llm",
    "openai",
    "anthropic",
    "azure-openai",
    "streaming",
    "custom-elements",
    "wc-bindable",
    "declarative",
    "no-provider-sdk",
    "framework-agnostic"
  ],
  "dependencies": {
    "@wc-bindable/core": "^0.4.0",
    "@wc-bindable/remote": "^0.4.0"
  },
  "author": "mogera551",
  "repository": {
    "type": "git",
    "url": "https://github.com/wc-bindable-protocol/wc-bindable-protocol.git",
    "directory": "packages/ai"
  },
  "license": "MIT"
}
