{
  "name": "@wc-bindable/auth0",
  "version": "0.4.0",
  "description": "Declarative Auth0 authentication component for Web Components. Framework-agnostic auth via wc-bindable-protocol.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./auto": {
      "types": "./src/auto/auto.d.ts",
      "default": "./src/auto/auto.min.js"
    }
  },
  "files": [
    "dist",
    "src/auto",
    "README.md",
    "README-LOCAL.md",
    "README-REMOTE.md",
    "SPEC-REMOTE.md"
  ],
  "scripts": {
    "prepack": "npm run build",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "npm run test:unit",
    "test:watch": "npm run test:unit:watch",
    "test:coverage": "npm run test:unit:coverage",
    "test:unit": "vitest run __tests__",
    "test:unit:watch": "vitest __tests__",
    "test:unit:coverage": "vitest run __tests__ --coverage --coverage.provider=v8 --coverage.reporter=text --coverage.include=src/**/*.ts --coverage.exclude=src/types.ts --coverage.exclude=src/index.ts --coverage.exclude=src/server/index.ts --coverage.exclude=src/auto/**/*.d.ts"
  },
  "keywords": [
    "web-components",
    "auth0",
    "authentication",
    "custom-elements",
    "wc-bindable",
    "declarative",
    "framework-agnostic"
  ],
  "dependencies": {
    "@wc-bindable/core": "^0.4.0",
    "@wc-bindable/remote": "^0.4.0",
    "jose": "^6.0.0"
  },
  "peerDependencies": {
    "@auth0/auth0-spa-js": "^2.0.0",
    "ws": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "@auth0/auth0-spa-js": {
      "optional": true
    },
    "ws": {
      "optional": true
    }
  },
  "author": "mogera551",
  "repository": {
    "type": "git",
    "url": "https://github.com/wc-bindable-protocol/wc-bindable-protocol.git",
    "directory": "packages/auth0"
  },
  "license": "MIT",
  "devDependencies": {
    "@auth0/auth0-spa-js": "^2.19.1",
    "@types/ws": "^8.18.1",
    "ws": "^8.18.2"
  }
}
