{
  "name": "@wc-bindable/hawc-stripe",
  "version": "0.4.0",
  "description": "Declarative Stripe payments component for Web Components. Server-side intent creation, browser-direct card entry via Stripe Elements, no PCI scope expansion, via wc-bindable-protocol.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "SPEC.md"
  ],
  "scripts": {
    "prepack": "npm run build",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run __tests__",
    "test:watch": "vitest __tests__"
  },
  "keywords": [
    "web-components",
    "stripe",
    "payments",
    "payment-intent",
    "setup-intent",
    "3d-secure",
    "custom-elements",
    "wc-bindable",
    "hawc",
    "declarative"
  ],
  "dependencies": {
    "@wc-bindable/core": "^0.4.0",
    "@wc-bindable/remote": "^0.4.0"
  },
  "peerDependencies": {
    "stripe": "^17.0.0",
    "@stripe/stripe-js": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "stripe": { "optional": true },
    "@stripe/stripe-js": { "optional": true }
  },
  "author": "mogera551",
  "repository": {
    "type": "git",
    "url": "https://github.com/wc-bindable-protocol/wc-bindable-protocol.git",
    "directory": "packages/hawc-stripe"
  },
  "license": "MIT"
}
