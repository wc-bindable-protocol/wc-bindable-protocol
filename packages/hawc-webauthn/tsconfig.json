{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2021", "DOM"],
    "paths": {
      "@wc-bindable/core": ["../core/src/index.ts"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../core" }
  ]
}
